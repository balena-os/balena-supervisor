{
  "compilerOptions": {
    "rootDir": "./",
    "target": "ES2025",
    "module": "node20",
    "strict": true,
    "strictFunctionTypes": false,
    "strictPropertyInitialization": false,
    "preserveConstEnums": true,
    "inlineSourceMap": true,
    "outDir": "./build/",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "types": [
      "mocha"
    ],
    "paths": {
      "~/src/*": [
        "./src/*"
      ],
      "~/lib/*": [
        "./src/lib/*"
      ],
      "~/test-lib/*": [
        "./test/lib/*"
      ],
      "~/test-data/*": [
        "./test/data/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "typings/**/*.d.ts",
    "sync/**/*",
    "build-utils/**/*"
  ]
}
