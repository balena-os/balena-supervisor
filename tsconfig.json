{
  "compilerOptions": {
    "rootDir": "./",
    "target": "ES2024",
    "module": "node20",
    "strict": true,
    "strictFunctionTypes": false,
    "strictPropertyInitialization": false,
    "preserveConstEnums": true,
    "inlineSourceMap": true,
    "outDir": "./build/",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "typings/**/*.d.ts",
    "sync/**/*",
    "build-utils/**/*"
  ]
}
